# ==========================================
# AmberClaw AI OS Environment Configuration
# ==========================================

# 1. OS Core Settings
# -------------------
ENVIRONMENT=development         # development, staging, production
LOG_LEVEL=INFO                  # DEBUG, INFO, WARNING, ERROR
HEARTBEAT_INTERVAL_SEC=5
MAX_AUTO_BUDGET_USD=5.0

# 2. Intelligence Layer (LiteLLM routing)
# ---------------------------------------
# You only need the keys for the providers you intend to use.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...
DEEPSEEK_API_KEY=sk-...
OLLAMA_BASE_URL=http://localhost:11434

# 3. Memory Subsystem
# -------------------
MEM0_API_KEY=m0-...
CHROMA_HOST=localhost
CHROMA_PORT=8001

# 4. Multimodal & Voice
# ---------------------
ELEVENLABS_API_KEY=...
OPENAI_VOICE_KEY=...

# 5. Security & Sandbox
# ---------------------
ENABLE_CODE_EXECUTION=true
SANDBOX_RUNTIME=docker          # docker, modal, gvisor
EGRESS_BLOCKED=true             # Block agents from making arbitrary external network calls

# 6. Channels (Optional)
# ----------------------
TELEGRAM_BOT_TOKEN=...
DISCORD_BOT_TOKEN=...
SLACK_BOT_TOKEN=...
